{
  "name": "pkcard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build:web": "vite build",
    "build:electron": "vite build && electron-packager . \"PKCard Game\" --platform=win32 --arch=x64 --out=release --overwrite",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^41.7.0",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^5.2.0",
    "vite-plugin-electron": "^0.29.1"
  },
  "build": {
    "appId": "com.pkcard.app",
    "productName": "PKCard Game",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    }
  }
}
